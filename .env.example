# aidocs server configuration.
#
# Copy to `.env` (or pass via your orchestrator's secret store) and fill in.
# Run with the published image, e.g.:
#   docker run -p 8080:8080 --env-file .env ghcr.io/anuragrao04/aidocs:<version>
#
# Pin an exact tag or digest in production; avoid :latest.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Postgres connection string. Migrations run automatically at startup unless
# AIDOCS_MIGRATE=false.
DATABASE_URL=postgres://aidocs:aidocs@localhost:5432/aidocs?sslmode=disable

# S3-compatible bucket that stores the uploaded HTML versions.
BLOB_BUCKET=aidocs-documents

# Public URL where the web UI / API is served. Injected into index.html so the
# frontend can render correct copy-paste commands. No trailing slash, no path.
APP_ORIGIN=https://aidocs.example.com

# Public URL where uploaded HTML is sandbox-rendered. MUST be a different origin
# from APP_ORIGIN in production (isolates untrusted document HTML). May equal
# APP_ORIGIN only for local/non-production. No trailing slash, no path.
RENDER_ORIGIN=https://render.aidocs.example.com

# Google OAuth web client credentials. The authorized redirect URI must be
# <APP_ORIGIN>/v1/auth/google/callback.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Session signing key. At least 32 random bytes (e.g. `openssl rand -hex 32`).
SESSION_SECRET=

# ---------------------------------------------------------------------------
# Deployment type
# ---------------------------------------------------------------------------

# "public" (default): anyone with a Google account can sign in; sharing with
#   everyone means "anyone with the link".
# "org": Google login is gated to AIDOCS_ORG_DOMAINS; sharing with everyone
#   means "anyone in <org>", because only org members can authenticate.
AIDOCS_DEPLOYMENT=public

# Required when AIDOCS_DEPLOYMENT=org. Comma-separated org domains; supports
# multiple domains (e.g. acquisitions). These are the login gate.
# AIDOCS_ORG_DOMAINS=acme.com,acme-labs.io

# Optional org display name used in share-UI copy (e.g. "Anyone in Acme").
# AIDOCS_ORG_NAME=Acme

# Public deployments only: optionally restrict logins to specific email
# domains. On an org deployment, AIDOCS_ORG_DOMAINS is the gate instead.
# ALLOWED_OAUTH_DOMAINS=example.com,company.com

# ---------------------------------------------------------------------------
# Blob storage (optional / S3-compatible tuning)
# ---------------------------------------------------------------------------

# AWS region for the S3 client (falls back to AWS_REGION, then us-east-1).
# BLOB_REGION=us-east-1

# Custom S3 endpoint for MinIO, Cloudflare R2, etc.
# BLOB_ENDPOINT=

# Set true for MinIO and most non-AWS S3 implementations.
# BLOB_FORCE_PATH_STYLE=false

# Override the AWS-SDK default credential chain when needed.
# BLOB_ACCESS_KEY_ID=
# BLOB_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Server (optional)
# ---------------------------------------------------------------------------

# TCP listen address.
# AIDOCS_ADDR=:8080

# Run database migrations on boot. Set false to manage migrations yourself.
# AIDOCS_MIGRATE=true

# Build revision exposed at /commit.txt (usually set by the image build).
# AIDOCS_COMMIT_SHA=
